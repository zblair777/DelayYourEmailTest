{
  "id": "1e7e38da-7ad6-429a-9c6f-81aa1b9c9344",
  "version": "1.0.0.4",
  "provider": "BigCloudConsultants",
  "defaultLocale": "en-US",

  "displayName": {
    "short": "Delay Your Emails"
  },
  "description": {
    "short": "Delay your outgoing emails.",
    "long": "An Outlook Add-in that delays emails by a chosen number of hours."
  },

  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "80": "assets/icon-80.png"
  },

  "supportUrl": "https://learn.microsoft.com/office/dev/add-ins/overview/office-add-in-code-samples",

  "permissions": "ReadWriteItem",

  "hosts": ["Mailbox"],

  "appDomains": [
    "https://icy-field-029eab10f.3.azurestaticapps.net"
  ],

  "formSettings": {
    "itemRead": {
      "desktop": {
        "sourceLocation": "https://icy-field-029eab10f.3.azurestaticapps.net/taskpane.html",
        "requestedHeight": 250
      }
    }
  },

  "runtime": {
    "commandsRuntimeUrl": "https://icy-field-029eab10f.3.azurestaticapps.net/commands.html"
  },

  "resources": {
    "urls": {
      "taskpane": "https://icy-field-029eab10f.3.azurestaticapps.net/taskpane.html",
      "commands": "https://icy-field-029eab10f.3.azurestaticapps.net/commands.html",
      "runtime": "https://icy-field-029eab10f.3.azurestaticapps.net/commands.html"
    },
    "strings": {
      "groupLabel": {
        "short": "Delay Email"
      },
      "taskpaneButton": {
        "short": "Show Taskpane",
        "long": "Open the Delay Email taskpane."
      },
      "actionButton": {
        "short": "Perform Action",
        "long": "Perform the delay email action."
      }
    }
  },

  "extensionPoints": {
    "messageCompose": {
      "commandSurface": {
        "groups": [
          {
            "id": "msgReadGroup",
            "label": "Delay Email",
            "controls": [
              {
                "id": "msgReadOpenPaneButton",
                "type": "showTaskpane",
                "label": "Show Taskpane",
                "icon": {
                  "16": "assets/icon-16.png",
                  "32": "assets/icon-32.png",
                  "80": "assets/icon-80.png"
                },
                "taskpaneUrl": "taskpane"
              },
              {
                "id": "ActionButton",
                "type": "executeFunction",
                "label": "Perform Action",
                "icon": {
                  "16": "assets/icon-16.png",
                  "32": "assets/icon-32.png",
                  "80": "assets/icon-80.png"
                },
                "functionName": "action"
              }
            ]
          }
        ]
      }
    },

    "mobile": {
      "launchEvents": [
        {
          "type": "OnNewMessageCompose",
          "functionName": "onNewMessageComposeHandler",
          "sourceLocation": "https://icy-field-029eab10f.3.azurestaticapps.net/commands.html"
        }
      ]
    }
  }
}
